{
  "name": "novacode-api",
  "version": "1.0.0",
  "description": "Nova Code backend – Fastify + node-pty",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node build/index.js",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.60.0",
    "@agentclientprotocol/sdk": "^1.2.1",
    "@fastify/auth": "^5.0.4",
    "@fastify/cors": "^11.3.0",
    "@fastify/static": "^10.1.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@fastify/websocket": "^11.3.0",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@sinclair/typebox": "^0.34.52",
    "fastify": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "node-pty": "^1.1.0",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "strip-ansi": "^7.2.0",
    "uuid": "^14.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.9.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
