{
  "name": "novacode-api",
  "version": "1.0.0",
  "description": "Nova Code backend – Fastify + node-pty",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node build/index.js",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.57.0",
    "@agentclientprotocol/sdk": "^1.2.0",
    "@fastify/auth": "^5.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^8.1.1",
    "@fastify/type-provider-typebox": "^5.1.0",
    "@fastify/websocket": "^11.0.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.0.0",
    "@sinclair/typebox": "^0.34.33",
    "fastify": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "node-pty": "^1.0.0",
    "pg": "^8.19.0",
    "qrcode": "^1.5.4",
    "strip-ansi": "^7.2.0",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.5",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.14",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
