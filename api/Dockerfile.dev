FROM node:24

ENV PATH="/usr/local/bin:${PATH}"
ENV PATH="/root/.local/bin:${PATH}"

# Install Claude Code and Cursor Agent CLIs (same as production image)
RUN npm install -g @anthropic-ai/claude-code

# Install Cursor agent CLI
RUN curl https://cursor.com/install -fsS | bash

# Install Cursor ACP adapter
RUN npm install -g @blowmage/cursor-agent-acp

# The adapter's loadSession path updates metadata.model but not state.currentModel.
# Prefer metadata.model so existing Nova sessions honor model changes on the next prompt.
RUN node -e "const fs=require('fs'); const p='/usr/local/lib/node_modules/@blowmage/cursor-agent-acp/dist/session/manager.js'; let s=fs.readFileSync(p,'utf8'); s=s.replace(\"return session?.state.currentModel || 'auto';\", \"return session?.metadata?.model || session?.state.currentModel || 'auto';\"); fs.writeFileSync(p,s);"

# Install Mistral Vibe CLI
RUN curl -LsSf https://mistral.ai/vibe/install.sh | bash

# Install OpenCode CLI
RUN curl -fsSL https://opencode.ai/install | bash

# Install Codex + Codex ACP adapter
RUN npm install -g @openai/codex @zed-industries/codex-acp

# install gosu and other base tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl bash gosu openssh-client \
    && rm -rf /var/lib/apt/lists/*



WORKDIR /app

# Build context is repo root (same as production Dockerfile)
COPY api/package*.json ./
RUN npm ci

COPY api/tsconfig.json ./
COPY api/docker-entrypoint.dev.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

## generate prisma client
COPY api/prisma ./prisma
COPY api/prisma.config.ts ./prisma.config.ts
RUN npx prisma generate

EXPOSE 3000
ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["npm", "run", "dev"]

