FROM node:24

ENV PATH="/usr/local/bin:${PATH}"
ENV PATH="/root/.local/bin:${PATH}"

# Install Claude Code and Cursor Agent CLIs (same as production image)
RUN npm install -g @anthropic-ai/claude-code

# Install Cursor agent CLI
RUN curl https://cursor.com/install -fsS | bash

# Install Mistral Vibe CLI
RUN curl -LsSf https://mistral.ai/vibe/install.sh | bash

# Install OpenCode CLI
RUN curl -fsSL https://opencode.ai/install | bash

# Install Codex + Codex ACP adapter
RUN npm install -g @openai/codex @zed-industries/codex-acp

# Install Playwright core so agents can connect to a Playwright server
RUN npm install -g playwright-core

# install gosu and other base tools (ffmpeg so agents can analyse video)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl bash gosu openssh-client ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# npm workspaces: install everything from the repo root
WORKDIR /app
COPY package.json package-lock.json ./
COPY shared/ shared/
COPY api/package.json api/
COPY api/prisma api/prisma
COPY api/prisma.config.ts api/
COPY dashboard/package.json dashboard/
RUN npm ci

COPY api/tsconfig.json api/
COPY api/docker-entrypoint.dev.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# The API runs from its workspace dir (src is bind-mounted here by compose)
WORKDIR /app/api
RUN npx prisma generate

EXPOSE 3000
ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["npm", "run", "dev"]
