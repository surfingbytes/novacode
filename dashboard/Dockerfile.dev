FROM node:24-bookworm-slim

# Build tools for node-pty's native addon (installed via the root workspace)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ \
    && rm -rf /var/lib/apt/lists/*

# npm workspaces: install everything from the repo root
WORKDIR /app
COPY package.json package-lock.json ./
COPY shared/ shared/
COPY api/package.json api/
COPY api/prisma api/prisma
COPY api/prisma.config.ts api/
COPY dashboard/package.json dashboard/
RUN npm ci

COPY dashboard/vite.config.ts dashboard/
COPY dashboard/tsconfig.json dashboard/tsconfig.app.json dashboard/tsconfig.node.json dashboard/
COPY dashboard/env.d.ts dashboard/
COPY dashboard/index.html dashboard/

# Vite dev server runs from the dashboard workspace dir (src is bind-mounted by compose)
WORKDIR /app/dashboard

EXPOSE 8080

CMD ["npm", "run", "dev"]
