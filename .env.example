# Copy this file to .env and fill in the values.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# The API builds the connection URL as:
#   postgresql://POSTGRES_USER:POSTGRES_PASSWORD@POSTGRES_HOST:POSTGRES_PORT/POSTGRES_DB
# Advanced: set DATABASE_URL directly to override all POSTGRES_* vars.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=novacode
POSTGRES_HOST=postgres        # "postgres" when using docker-compose, else your DB host
POSTGRES_PORT=5432

# ── Auth ──────────────────────────────────────────────────────────────────────
# Long random string — generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3030

# Max upload size for chat attachments (videos) in MiB, measured on the
# base64-encoded request body (~4/3× the actual file size). Default: 512.
#UPLOAD_BODY_LIMIT_MB=512

# ── File ownership inside containers ─────────────────────────────────────────
# Ensures files written by the container match your host user.
# Run: export UID=$(id -u) GID=$(id -g)  before docker compose up, or set here.
UID=1000
GID=1000
